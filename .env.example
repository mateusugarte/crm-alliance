# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PostgreSQL direto (memória do agente Alice) — normalmente a mesma instância do Supabase,
# usando a "Connection string" (modo "Session pooler" ou direto) do painel do Supabase
PG_MEMORY_URL=

# UazAPI — usada para envio de mensagens (chat individual e disparos/reativação)
UAZAPI_BASE_URL=

# WhatsApp Business API (Meta) — mantido apenas para validação do webhook legado
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# N8N — repassa mensagens recebidas da Meta para o agente
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# OpenAI — agente Alice (chat) e geração de variações de mensagem dos disparos
OPENAI_API_KEY=
OPENAI_MODEL_ALICE=gpt-4.1-mini

# Disparos — deixe em branco. O motor de disparo roda dentro deste mesmo serviço
# (Socket.io na mesma porta); NEXT_PUBLIC_DISPARO_API_URL só é necessário se um dia
# ele voltar a rodar como serviço externo separado.
NEXT_PUBLIC_DISPARO_API_URL=

# App
NEXT_PUBLIC_APP_URL=
NODE_ENV=production
