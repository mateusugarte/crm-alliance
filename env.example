# ============================================================
# CRM ALLIANCE — VARIÁVEIS DE AMBIENTE
# ============================================================
# ATENÇÃO: Este arquivo é o EXEMPLO. Nunca suba o .env.local para o Git.
# Copie este arquivo para .env.local e preencha os valores reais.
# O .env.local está no .gitignore — confirme isso antes de qualquer commit.
# ============================================================

# ------------------------------------------------------------
# SUPABASE — Banco de dados, Auth e Realtime
# ------------------------------------------------------------
# URL pública do projeto (pode ser exposta no cliente)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Chave anon/pública — usada no browser (sem acesso privilegiado)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️  SERVICE ROLE — NUNCA adicionar prefixo NEXT_PUBLIC_ aqui
# ⚠️  Esta chave bypassa todas as RLS — usar SOMENTE em API routes server-side
# ⚠️  Se exposta, acesso root total ao banco. Rolar imediatamente se vazar.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------
# WHATSAPP BUSINESS API — Meta Cloud API (oficial)
# ------------------------------------------------------------
# Token de acesso permanente (Meta Business Suite → Configurações → Tokens)
WHATSAPP_ACCESS_TOKEN=EAABs...

# ID do número de telefone cadastrado na Meta
WHATSAPP_PHONE_NUMBER_ID=123456789

# ID da conta WhatsApp Business
WHATSAPP_BUSINESS_ACCOUNT_ID=987654321

# App Secret (Meta for Developers → App → Configurações → App Secret)
# Usado para validar X-Hub-Signature-256 nos webhooks
WHATSAPP_APP_SECRET=abc123...

# String aleatória que você define — usada para verificar o webhook na Meta
# Gere com: openssl rand -hex 32
WHATSAPP_VERIFY_TOKEN=seu_token_aleatorio_aqui

# ------------------------------------------------------------
# N8N — Orquestrador do agente de IA
# ------------------------------------------------------------
# URL do webhook N8N que processa mensagens recebidas
N8N_WEBHOOK_URL=https://seu-n8n.railway.app/webhook/alliance

# Secret para autenticar chamadas Next.js → N8N
# Gere com: openssl rand -hex 32
N8N_WEBHOOK_SECRET=seu_secret_aleatorio_aqui

# ------------------------------------------------------------
# ANTHROPIC — Claude API (agente de IA)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# AMBIENTE
# ------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
